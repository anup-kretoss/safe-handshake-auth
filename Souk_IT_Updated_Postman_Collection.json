{
  "info": {
    "_postman_id": "souk-it-updated-2026",
    "name": "Souk IT - Updated API Collection",
    "description": "Updated collection with new wishlist and notification APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('ACCESS_TOKEN', jsonData.access_token);",
                  "    pm.collectionVariables.set('USER_ID', jsonData.user.id);",
                  "    console.log('✅ Access token saved:', jsonData.access_token);",
                  "    console.log('✅ User ID saved:', jsonData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "apikey", "value": "{{SUPABASE_ANON_KEY}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{TEST_EMAIL}}\",\n    \"password\": \"{{TEST_PASSWORD}}\"\n}"
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/auth/v1/token?grant_type=password",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["auth", "v1", "token"],
              "query": [{"key": "grant_type", "value": "password"}]
            }
          }
        }
      ]
    },
    {
      "name": "Wishlist (New API)",
      "item": [
        {
          "name": "Get Wishlist",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"}
            ],
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/wishlist",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "wishlist"]
            },
            "description": "Get all wishlist items for the authenticated user"
          }
        },
        {
          "name": "Add to Wishlist",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"product_id\": \"{{PRODUCT_ID}}\",\n    \"isWishlist\": true\n}"
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/wishlist",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "wishlist"]
            },
            "description": "Add a product to wishlist using isWishlist: true"
          }
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"product_id\": \"{{PRODUCT_ID}}\",\n    \"isWishlist\": false\n}"
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/wishlist",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "wishlist"]
            },
            "description": "Remove a product from wishlist using isWishlist: false"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"targetUserId\": \"{{TARGET_USER_ID}}\",\n    \"title\": \"New Message\",\n    \"message\": \"Someone is interested in your item!\"\n}"
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/send-notification",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "send-notification"]
            },
            "description": "Send push notification and save to database"
          }
        },
        {
          "name": "Get All Notifications",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"}
            ],
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/notifications?limit=50&offset=0",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "notifications"],
              "query": [
                {"key": "limit", "value": "50", "description": "Number of notifications to fetch"},
                {"key": "offset", "value": "0", "description": "Pagination offset"}
              ]
            },
            "description": "Get all notifications for the authenticated user"
          }
        },
        {
          "name": "Get Unread Notifications",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"}
            ],
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/notifications?unread_only=true&limit=50",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "notifications"],
              "query": [
                {"key": "unread_only", "value": "true", "description": "Only fetch unread notifications"},
                {"key": "limit", "value": "50"}
              ]
            },
            "description": "Get only unread notifications"
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"notification_id\": \"{{NOTIFICATION_ID}}\"\n}"
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/notifications",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "notifications"]
            },
            "description": "Mark a specific notification as read"
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"mark_all_read\": true\n}"
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/notifications",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "notifications"]
            },
            "description": "Mark all notifications as read"
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"notification_id\": \"{{NOTIFICATION_ID}}\"\n}"
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/notifications",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "notifications"]
            },
            "description": "Delete a specific notification"
          }
        },
        {
          "name": "Delete All Read Notifications",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"delete_all_read\": true\n}"
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/notifications",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "notifications"]
            },
            "description": "Delete all read notifications"
          }
        }
      ]
    }
  ],
